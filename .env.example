# Database (Railway provides this automatically when you add a PostgreSQL service)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Server
PORT=3002
NODE_ENV=production

# Client URL (set to your Railway public domain)
CLIENT_URL=https://your-app.up.railway.app

# Google OAuth (required for Gmail & Calendar integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/api/v1/auth/google/callback

# Authentication (required in production)
JWT_SECRET=<random-64-char-string>
JWT_REFRESH_SECRET=<random-64-char-string>
ALLOWED_EMAILS=your@gmail.com
TOKEN_ENCRYPTION_KEY=<random-32-byte-hex-string>

# Sync
SYNC_INTERVAL_SECONDS=60
EMAIL_SYNC_ENABLED=true
