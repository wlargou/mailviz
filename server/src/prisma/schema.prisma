generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PHASE 1 MODELS ────────────────────────────────

model Task {
  id             String       @id @default(uuid())
  title          String       @db.VarChar(255)
  description    String?      @db.Text
  status         String       @default("TODO") @db.VarChar(100)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?    @map("due_date")
  position       Int          @default(0)
  estimatedMinutes Int?       @map("estimated_minutes")
  customerId     String?      @map("customer_id")
  assignedToId   String?      @map("assigned_to_id")
  userId         String       @map("user_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  labels     TaskLabel[]
  mailToTask MailToTask?
  shares     TaskShare[]
  customer   Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedTo User?        @relation("TaskAssignments", fields: [assignedToId], references: [id], onDelete: SetNull)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([customerId])
  @@index([userId])
  @@index([assignedToId])
  @@map("tasks")
}

model TaskStatus {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  label     String   @db.VarChar(100)
  color     String   @default("#4589ff") @db.VarChar(7)
  position  Int      @default(0)
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("UserTaskStatuses", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("task_statuses")
}

model CompanyCategory {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  label     String   @db.VarChar(100)
  color     String   @default("#4589ff") @db.VarChar(7)
  position  Int      @default(0)
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  customers Customer[]
  user      User       @relation("UserCompanyCategories", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("company_categories")
}

model Customer {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(255)
  email      String?  @db.VarChar(255)
  phone      String?  @db.VarChar(50)
  company    String?  @db.VarChar(255)
  website    String?  @db.VarChar(255)
  domain     String?  @db.VarChar(255)
  logoUrl    String?  @map("logo_url") @db.VarChar(500)
  notes      String?  @db.Text
  categoryId String?  @map("category_id")
  isVip      Boolean  @default(false) @map("is_vip")
  isInternal Boolean  @default(false) @map("is_internal")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category       CompanyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  tasks          Task[]
  calendarEvents CalendarEventCustomer[]
  emails         Email[]
  deals          Deal[]

  @@unique([userId, domain])
  @@index([categoryId])
  @@index([userId])
  @@map("customers")
}

model Contact {
  id         String   @id @default(uuid())
  firstName  String   @db.VarChar(100) @map("first_name")
  lastName   String   @db.VarChar(100) @map("last_name")
  email      String?  @db.VarChar(255)
  phone      String?  @db.VarChar(50)
  role       String?  @db.VarChar(100)
  isVip      Boolean  @default(false) @map("is_vip")
  customerId String   @map("customer_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([email])
  @@map("contacts")
}

model Label {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  color     String   @db.VarChar(7)
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  tasks TaskLabel[]
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("labels")
}

model TaskLabel {
  taskId  String @map("task_id")
  labelId String @map("label_id")

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_labels")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── AUTH MODELS ──────────────────────────────────

model User {
  id        String      @id @default(uuid())
  email     String      @unique @db.VarChar(255)
  name      String?     @db.VarChar(255)
  avatarUrl String?     @map("avatar_url") @db.VarChar(500)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  googleAuth        GoogleAuth?
  tasks             Task[]
  customers         Customer[]
  labels            Label[]
  emails            Email[]
  calendarEvents    CalendarEvent[]
  taskStatuses      TaskStatus[]      @relation("UserTaskStatuses")
  companyCategories CompanyCategory[] @relation("UserCompanyCategories")
  dealPartners      DealPartner[]     @relation("UserDealPartners")
  deals             Deal[]
  emailSharesSent     EmailThreadShare[] @relation("EmailSharesSent")
  emailSharesReceived EmailThreadShare[] @relation("EmailSharesReceived")
  dealSharesSent      DealShare[]        @relation("DealSharesSent")
  dealSharesReceived  DealShare[]        @relation("DealSharesReceived")
  taskSharesSent      TaskShare[]        @relation("TaskSharesSent")
  taskSharesReceived  TaskShare[]        @relation("TaskSharesReceived")
  taskAssignments     Task[]             @relation("TaskAssignments")
  scheduledEmails     ScheduledEmail[]
  auditLogs           AuditLog[]

  @@map("users")
}

// ─── PHASE 2 MODELS ────────────────────────────────

model GoogleAuth {
  id           String    @id @default(uuid())
  accessToken  String    @db.Text @map("access_token")
  refreshToken String    @db.Text @map("refresh_token")
  tokenExpiry  DateTime  @map("token_expiry")
  email        String?   @db.VarChar(255)
  scope        String?   @db.Text
  lastSyncAt   DateTime? @map("last_sync_at")
  lastMailSyncAt DateTime? @map("last_mail_sync_at")
  lastHistoryId      String?   @map("last_history_id") @db.VarChar(50)
  calendarSyncToken  String?   @map("calendar_sync_token") @db.Text
  userId       String    @unique @map("user_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_auth")
}

model CalendarEvent {
  id            String    @id @default(uuid())
  googleEventId String?   @map("google_event_id")
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  startTime     DateTime  @map("start_time")
  endTime       DateTime  @map("end_time")
  location      String?
  isAllDay       Boolean   @default(false) @map("is_all_day")
  calendarId     String?   @map("calendar_id")
  colorId        String?   @map("color_id")
  attendees      Json?     @db.JsonB
  conferenceLink    String?   @map("conference_link")
  recurringEventId  String?   @map("recurring_event_id")
  recurrence        String[]  @default([])
  syncedAt          DateTime? @map("synced_at")
  userId        String    @map("user_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  customers CalendarEventCustomer[]
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googleEventId])
  @@index([startTime, endTime])
  @@index([userId])
  @@map("calendar_events")
}

model CalendarEventCustomer {
  calendarEventId String @map("calendar_event_id")
  customerId      String @map("customer_id")

  calendarEvent CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([calendarEventId, customerId])
  @@map("calendar_event_customers")
}

model Email {
  id             String    @id @default(uuid())
  gmailMessageId String?   @map("gmail_message_id")
  threadId       String?   @map("thread_id")
  subject        String    @db.VarChar(500)
  from           String    @db.VarChar(255)
  fromName       String?   @db.VarChar(255) @map("from_name")
  to             String[]
  cc             String[]
  bcc            String[]
  messageId      String?   @map("message_id") @db.VarChar(500)
  inReplyTo      String?   @map("in_reply_to") @db.VarChar(500)
  references     String?   @map("references") @db.Text
  snippet        String?   @db.Text
  body           String?   @db.Text
  receivedAt     DateTime  @map("received_at")
  isRead         Boolean   @default(false) @map("is_read")
  isStarred      Boolean   @default(false) @map("is_starred")
  isArchived     Boolean   @default(false) @map("is_archived")
  isTrashed      Boolean   @default(false) @map("is_trashed")
  hasAttachment  Boolean   @default(false) @map("has_attachment")
  sizeEstimate   Int?      @map("size_estimate")
  labelIds       String[]  @map("label_ids")
  syncedAt       DateTime? @map("synced_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  customerId String?   @map("customer_id")
  userId     String    @map("user_id")
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailToTask      MailToTask?
  attachments     EmailAttachment[]
  scheduledReplies ScheduledEmail[]

  @@unique([userId, gmailMessageId])
  @@index([receivedAt])
  @@index([threadId])
  @@index([customerId])
  @@index([isRead])
  @@index([from])
  @@index([userId])
  @@map("emails")
}

model EmailAttachment {
  id                String @id @default(uuid())
  emailId           String @map("email_id")
  gmailAttachmentId String @map("gmail_attachment_id")
  filename          String @db.VarChar(500)
  mimeType          String @db.VarChar(255)
  size              Int

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@map("email_attachments")
}

model MailToTask {
  id             String   @id @default(uuid())
  emailId        String   @unique @map("email_id")
  taskId         String   @unique @map("task_id")
  conversionNote String?  @db.Text @map("conversion_note")
  createdAt      DateTime @default(now()) @map("created_at")

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)
  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("mail_to_tasks")
}

// ─── DEAL REGISTRATION MODELS ─────────────────────

model DealPartner {
  id              String   @id @default(uuid())
  name            String   @db.VarChar(255)
  registrationUrl String?  @map("registration_url") @db.VarChar(500)
  logoUrl         String?  @map("logo_url") @db.VarChar(500)
  userId          String   @map("user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  deals Deal[]
  user  User   @relation("UserDealPartners", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("deal_partners")
}

model Deal {
  id         String    @id @default(uuid())
  title      String    @db.VarChar(255)
  partnerId  String    @map("partner_id")
  customerId String?   @map("customer_id")
  products   String?   @db.Text
  status     String    @default("TO_CHALLENGE") @db.VarChar(50)
  expiryDate DateTime? @map("expiry_date")
  notes      String?   @db.Text
  userId     String    @map("user_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  partner  DealPartner @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares   DealShare[]

  @@index([partnerId])
  @@index([customerId])
  @@index([status])
  @@index([userId])
  @@map("deals")
}

// ─── SHARING MODELS ──────────────────────────────

model EmailThreadShare {
  id               String   @id @default(uuid())
  threadId         String   @map("thread_id")
  sharedByUserId   String   @map("shared_by_user_id")
  sharedWithUserId String   @map("shared_with_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  sharedBy   User @relation("EmailSharesSent", fields: [sharedByUserId], references: [id], onDelete: Cascade)
  sharedWith User @relation("EmailSharesReceived", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([threadId, sharedWithUserId])
  @@index([sharedWithUserId])
  @@index([sharedByUserId])
  @@index([threadId])
  @@map("email_thread_shares")
}

model DealShare {
  id               String   @id @default(uuid())
  dealId           String   @map("deal_id")
  sharedByUserId   String   @map("shared_by_user_id")
  sharedWithUserId String   @map("shared_with_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  deal       Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sharedBy   User @relation("DealSharesSent", fields: [sharedByUserId], references: [id], onDelete: Cascade)
  sharedWith User @relation("DealSharesReceived", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([dealId, sharedWithUserId])
  @@index([sharedWithUserId])
  @@index([sharedByUserId])
  @@index([dealId])
  @@map("deal_shares")
}

model TaskShare {
  id               String   @id @default(uuid())
  taskId           String   @map("task_id")
  sharedByUserId   String   @map("shared_by_user_id")
  sharedWithUserId String   @map("shared_with_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sharedBy   User @relation("TaskSharesSent", fields: [sharedByUserId], references: [id], onDelete: Cascade)
  sharedWith User @relation("TaskSharesReceived", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([taskId, sharedWithUserId])
  @@index([sharedWithUserId])
  @@index([sharedByUserId])
  @@index([taskId])
  @@map("task_shares")
}

// ─── SCHEDULED EMAILS ──────────────────────────────

model ScheduledEmail {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  status      String   @default("pending") @db.VarChar(20)
  sendAt      DateTime @map("send_at")
  mode        String   @db.VarChar(20)

  to          String[]
  cc          String[] @default([])
  bcc         String[] @default([])
  subject     String   @db.VarChar(500)
  htmlBody    String   @db.Text @map("html_body")

  attachments Json?    @default("[]")

  replyToEmailId             String?  @map("reply_to_email_id")
  forwardExistingAttachments String[] @default([]) @map("forward_existing_attachments")

  sentMessageId String? @map("sent_message_id")
  sentThreadId  String? @map("sent_thread_id")
  errorMessage  String? @map("error_message") @db.Text
  retryCount    Int     @default(0) @map("retry_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyToEmail Email? @relation(fields: [replyToEmailId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status, sendAt])
  @@map("scheduled_emails")
}

// ─── AUDIT LOG ──────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  action      String   @db.VarChar(50)
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String?  @map("entity_id")
  details     Json?    @db.JsonB
  status      String   @default("success") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
